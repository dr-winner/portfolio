# Copy to `.env` and fill in values. Never commit `.env`.

# Prisma — local dev: file-based SQLite. Production (Vercel): use a hosted DB URL, e.g. Vercel Postgres / Neon / Supabase.
DATABASE_URL="file:./prisma/dev.db"

# Admin session (HMAC cookie). Use a long random string in production.
SESSION_SECRET="change-me-to-a-long-random-string"

# Admin login — use `npm run admin:hash -- "your-password"` and paste the output (no $ signs if your shell mangles them).
# On Vercel, prefer base64 to avoid special-character issues: echo -n 'YOUR_HASH' | base64
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH=""
# ADMIN_PASSWORD_HASH_B64=""

# GitHub API — private contributions graph on the site (optional).
# GITHUB_TOKEN="ghp_..."

# Site console / terminal AI replies (optional; without it, local commands only).
# GROQ_API_KEY=""
# GROQ_MODEL="llama-3.3-70b-versatile"

# Analytics fingerprinting salt (optional; falls back to SESSION_SECRET).
# ANALYTICS_SALT=""
